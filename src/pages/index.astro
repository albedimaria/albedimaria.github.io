---
import Layout from '../layouts/Layout.astro';
import Nav from '../components/Nav.astro';
import Hero from '../components/Hero.astro';
import Work from '../components/Work.astro';
import Services from '../components/Services.astro';
import About from '../components/About.astro';
import Background from '../components/Background.astro';
import Contact from '../components/Contact.astro';
import BackToTop from '../components/BackToTop.astro';
---

<Layout>
  <Nav />
  <main>
    <Hero />
    <Work />
    <Services />
    <About />
    <Background />
    <Contact />
  </main>

  <footer class="border-t border-bone/10 bg-ink">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-2 px-6 py-8 font-mono text-[11px] text-text-dim">
      <span>© 2026 Alberto Di Maria</span>
      <span>Milan, Italy · built with Astro</span>
    </div>
  </footer>

  <BackToTop />
</Layout>
