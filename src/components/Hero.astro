---
import WaveSignature from './WaveSignature.astro';
import { ui, heroHook, heroSub, heroPhotoRole, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const hook = heroHook[lang];
const sub = heroSub[lang];
const cueLabel: Record<Lang, string> = { en: 'Meet my agent', it: 'Vai al mio agente', es: 'Ir a mi agente' };
---

<!-- Hero: business-first question hook + photo. The D10S agent moved to its
     own full-width band below (see AgentDemo.astro). -->
<section id="top" class="hero-glow relative flex min-h-[100svh] flex-col overflow-hidden">
  <WaveSignature top="68%" />

  <div class="relative z-10 flex flex-1 items-center">
    <div class="mx-auto grid-12 w-full max-w-6xl px-6 pb-6 pt-24">
    <!-- copy -->
    <div class="col-span-12 lg:col-span-7">
      <p class="mb-7 flex items-center gap-2.5 font-mono text-[13px] lowercase tracking-wide text-text-muted">
        <span class="h-2 w-2 rounded-full bg-[#57c98a]" aria-hidden="true"></span>
        {t.hero_available}
      </p>

      <h1 class="font-display text-[clamp(52px,6.8vw,96px)] font-[550] leading-[0.96] tracking-[-0.015em] text-bone">
        {hook.line1}<br /><em class="font-[420] not-italic text-accent-lg italic">{hook.accent}</em>
      </h1>

      <p class="mt-7 max-w-[34ch] text-[18px] leading-[1.5] md:text-[20px]">
        <span class="font-medium text-bone">{sub.lead}</span><br />
        <span class="text-text-muted">{sub.follow}</span>
      </p>

      <div class="mt-9 flex flex-wrap items-center gap-x-7 gap-y-4">
        <a href="#contact" class="btn-primary">
          {t.hero_cta_primary}
        </a>
        <a href="#services" class="link-draw font-mono text-[14px] text-accent-txt transition-colors hover:text-bone">
          {t.hero_cta_secondary}
        </a>
      </div>
    </div>

    <!-- photo — name & role live INSIDE the frame on a bottom scrim -->
    <div class="col-span-12 mt-4 max-w-[300px] self-start lg:col-span-4 lg:col-start-9 lg:mt-[47px] lg:max-w-none">
      <div class="hero-photo-frame relative aspect-square overflow-hidden rounded-[var(--radius-card)] border border-bone/15 shadow-[0_24px_70px_rgba(0,0,0,0.45)]">
        <img
          src="/images/alberto.webp"
          alt="Alberto Di Maria"
          width="900"
          height="900"
          class="h-full w-full object-cover"
        />
        <div class="absolute inset-x-0 bottom-0 bg-gradient-to-t from-ink/90 via-ink/45 to-transparent px-4 pb-3.5 pt-10">
          <p class="font-display text-[19px] font-[550] leading-tight text-bone">Alberto Di Maria</p>
          <p class="mt-0.5 font-mono text-[11px] uppercase tracking-[0.1em] text-text-muted">{heroPhotoRole[lang]}</p>
        </div>
      </div>
    </div>
    </div>
  </div>

  <div class="relative z-10 flex justify-center pb-9">
    <a href="#agent-demo" class="scroll-cue" aria-label={cueLabel[lang]}>
      <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.6" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 5v14" /><path d="M5 12l7 7 7-7" /></svg>
    </a>
  </div>
</section>
