---
import WaveSignature from './WaveSignature.astro';
import VoiceChat from './VoiceChat.tsx';
import { ui, voiceDemo, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const demo = voiceDemo[lang];
---

<!-- Hero "equation": name on the left, D10S (the live guide) on the right,
     the signature waves running through the whole scene as the agent's voice. -->
<section id="top" class="relative overflow-hidden">
  <WaveSignature top="70%" />

  <div
    class="relative z-10 mx-auto grid max-w-6xl items-center gap-y-12 px-6 pb-16 pt-16 md:pb-20 md:pt-24 lg:min-h-[min(calc(100svh-65px),820px)] lg:grid-cols-[1fr_0.92fr] lg:gap-x-16"
  >
    <div class="min-w-0">
      <h1 class="font-display text-6xl font-semibold leading-[0.92] tracking-tight text-bone md:text-8xl xl:text-[104px]">
        Alberto<br />Di Maria
      </h1>
      <p class="mt-6 font-mono text-[14px] tracking-wide text-text-muted md:text-[15px]">{t.hero_role}</p>
    </div>

    <div id="voice-chat" class="min-w-0">
      <h2 class="font-display text-[26px] font-semibold leading-snug text-bone md:text-[32px]">
        {demo.title}
      </h2>
      <div class="mt-6">
        <VoiceChat client:visible lang={lang} />
      </div>
    </div>
  </div>
</section>
