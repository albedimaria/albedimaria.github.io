---
import WaveSignature from './WaveSignature.astro';
import { ui, voiceDemo, voiceUi, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const demo = voiceDemo[lang];
const vu = voiceUi[lang];
---

<!-- Hero "equation": name on the left, D10S (the live guide) on the right,
     the signature waves running through the whole scene as the agent's voice. -->
<section id="top" class="relative overflow-hidden">
  <WaveSignature top="70%" />

  <div
    class="relative z-10 mx-auto grid max-w-6xl items-center gap-y-12 px-6 pb-16 pt-16 md:pb-20 md:pt-24 lg:min-h-[min(calc(100svh-65px),820px)] lg:grid-cols-[1fr_0.92fr] lg:gap-x-16"
  >
    <div class="min-w-0">
      <h1 class="font-display text-6xl font-semibold leading-[0.92] tracking-tight text-bone md:text-8xl xl:text-[104px]">
        Alberto<br />Di Maria
      </h1>
      <p class="mt-6 font-mono text-[14px] tracking-wide text-text-muted md:text-[15px]">{t.hero_role}</p>
    </div>

    <div id="voice-chat" class="min-w-0">
      <h2 class="font-display text-[26px] font-semibold leading-snug text-bone md:text-[32px]">
        {demo.title}
      </h2>
      <div class="mt-6">
        <!-- Static panel shell — renders with ZERO JS. The ~680 KB React +
             ElevenLabs SDK is imported and mounted here only on the first
             click (see the script below). -->
        <div
          id="d10s-panel"
          data-lang={lang}
          class="mx-auto w-full max-w-xl rounded-[var(--radius-card)] border border-bone/10 bg-surface p-4 shadow-[0_0_50px_rgba(0,0,0,0.4)] sm:p-5"
        >
          <div class="space-y-3">
            <div class="flex flex-wrap items-center justify-center gap-2.5">
              <button
                type="button"
                data-d10s="voice"
                class="flex items-center gap-2 rounded-full bg-oxblood px-6 py-2.5 font-mono text-[13px] uppercase tracking-[0.15em] text-[#f6dfe4] transition hover:bg-oxblood/85"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                  <rect x="9" y="3" width="6" height="11" rx="3" /><path d="M5 11a7 7 0 0 0 14 0" /><path d="M12 18v3" />
                </svg>
                {vu.talk}
              </button>
              <button
                type="button"
                data-d10s="text"
                class="flex items-center gap-2 rounded-full border border-bone/35 px-5 py-2.5 font-mono text-[13px] uppercase tracking-[0.15em] text-text-muted transition hover:border-bone/60 hover:text-bone"
              >
                <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                  <rect x="3" y="7" width="18" height="11" rx="2" /><path d="M7 11h.01M11 11h.01M15 11h.01M17 11h.01M7 15h10" />
                </svg>
                {vu.type}
              </button>
            </div>
            <div class="flex flex-wrap justify-center gap-2 pt-0.5">
              {vu.chips.map((c) => (
                <button
                  type="button"
                  data-d10s="chip"
                  data-chip={c}
                  class="rounded-full border border-bone/12 bg-bone/[0.04] px-3 py-1.5 font-mono text-[12px] text-text-muted transition hover:border-oxblood-soft/60 hover:text-bone"
                >
                  {c}
                </button>
              ))}
            </div>
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Load the voice SDK only on the first interaction with the panel.
    const panel = document.getElementById('d10s-panel');
    if (panel) {
      let booted = false;
      const boot = async (btn: HTMLElement) => {
        if (booted) return;
        booted = true;
        const action = btn.dataset.d10s === 'chip' ? btn.dataset.chip! : btn.dataset.d10s!;
        const { mount } = await import('./voice-mount');
        mount(panel, (panel.dataset.lang as 'en' | 'it' | 'es') || 'en', action);
      };
      panel.querySelectorAll<HTMLElement>('[data-d10s]').forEach((b) =>
        b.addEventListener('click', () => boot(b))
      );
    }
  </script>
</section>
