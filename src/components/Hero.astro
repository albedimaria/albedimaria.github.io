---
import WaveSignature from './WaveSignature.astro';
---

<section id="top" class="relative overflow-hidden">
  <WaveSignature />

  <div class="relative z-10 mx-auto max-w-5xl px-6 pb-28 pt-24 md:pb-32 md:pt-32">
    <h1 class="font-display text-5xl font-semibold leading-[0.95] tracking-tight text-bone md:text-7xl">
      Alberto Di Maria
    </h1>
    <p class="mt-6 font-mono text-sm tracking-wide text-text-muted md:text-[15px]">
      AI PRODUCT ENGINEER <span class="text-oxblood-soft">·</span> agentic AI, voice agents &amp; audio
    </p>

    <div class="mt-9 flex flex-wrap items-center gap-3">
      <a
        href="#contact"
        class="rounded-[var(--radius-btn)] bg-bone px-5 py-3 font-mono text-sm font-medium text-ink transition hover:opacity-90"
      >
        Let's work together →
      </a>
      <a
        href="#work"
        class="rounded-[var(--radius-btn)] border border-bone/30 px-5 py-3 font-mono text-sm text-bone transition hover:border-bone/60"
      >
        View work ↓
      </a>
      <a
        href="/cv.pdf"
        class="rounded-[var(--radius-btn)] border border-bone/15 px-5 py-3 font-mono text-sm text-text-muted transition hover:text-bone"
      >
        Download CV
      </a>
    </div>
  </div>
</section>
