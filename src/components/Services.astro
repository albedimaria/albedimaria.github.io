---
import { servicesBand, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const band = servicesBand[lang];

// Line-art glyphs (draft — refined in the motion pass). One per card, in the
// brand language: bone strokes + oxblood accents, stroke 1.5.
const glyphs = [
  // 01 — site wireframe
  `<svg viewBox="0 0 300 168" fill="none" aria-hidden="true">
    <rect x="70" y="22" width="160" height="124" rx="6" stroke="#c3b5a9" stroke-opacity=".55" stroke-width="1.5"/>
    <line x1="70" y1="42" x2="230" y2="42" stroke="#c3b5a9" stroke-opacity=".35" stroke-width="1.5"/>
    <circle cx="80" cy="32" r="2.2" stroke="#9c3340" stroke-width="1.5"/>
    <circle cx="89" cy="32" r="2.2" stroke="#9c3340" stroke-width="1.5" opacity=".6"/>
    <rect x="82" y="54" width="64" height="8" rx="2" fill="#9c3340" fill-opacity=".8"/>
    <rect x="82" y="70" width="84" height="5" rx="2" fill="#c3b5a9" fill-opacity=".35"/>
    <rect x="82" y="81" width="72" height="5" rx="2" fill="#c3b5a9" fill-opacity=".25"/>
    <rect x="82" y="96" width="40" height="14" rx="3" stroke="#9c3340" stroke-width="1.5"/>
    <rect x="178" y="54" width="40" height="40" rx="4" stroke="#c3b5a9" stroke-opacity=".45" stroke-width="1.5"/>
    <path d="M178 86l12-12 10 8 16-16" stroke="#9c3340" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <rect x="82" y="120" width="40" height="16" rx="3" stroke="#c3b5a9" stroke-opacity=".45" stroke-width="1.5"/>
    <rect x="130" y="120" width="40" height="16" rx="3" stroke="#c3b5a9" stroke-opacity=".45" stroke-width="1.5"/>
    <rect x="178" y="120" width="40" height="16" rx="3" stroke="#9c3340" stroke-width="1.5"/>
  </svg>`,
  // 02 — automation node graph
  `<svg viewBox="0 0 300 168" fill="none" aria-hidden="true">
    <circle cx="86" cy="52" r="12" stroke="#c3b5a9" stroke-opacity=".55" stroke-width="1.5"/>
    <circle cx="86" cy="116" r="12" stroke="#c3b5a9" stroke-opacity=".55" stroke-width="1.5"/>
    <circle cx="150" cy="84" r="16" stroke="#9c3340" stroke-width="1.5"/>
    <circle cx="150" cy="84" r="6" stroke="#9c3340" stroke-width="1.5" opacity=".7"/>
    <circle cx="214" cy="52" r="12" stroke="#c3b5a9" stroke-opacity=".55" stroke-width="1.5"/>
    <circle cx="214" cy="116" r="12" stroke="#c3b5a9" stroke-opacity=".55" stroke-width="1.5"/>
    <path d="M97 57l38 21M97 111l38-21M165 77l38-21M165 91l38 21" stroke="#c3b5a9" stroke-opacity=".4" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M81 49h10M86 44v10" stroke="#c3b5a9" stroke-opacity=".7" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M81 116h10" stroke="#c3b5a9" stroke-opacity=".7" stroke-width="1.5" stroke-linecap="round"/>
    <path d="M209 48l4 5 7-9" stroke="#9c3340" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
    <path d="M209 112l4 5 7-9" stroke="#9c3340" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/>
  </svg>`,
  // 03 — handset + signature waves
  `<svg viewBox="0 0 300 168" fill="none" aria-hidden="true">
    <path d="M104 56c0-6 5-11 11-11h8c5 0 8 3 9 7l2 11c1 4-1 7-4 9l-5 4c6 14 17 25 31 31l4-5c2-3 5-5 9-4l11 2c4 1 7 4 7 9v8c0 6-5 11-11 11-48 0-72-39-72-72z" stroke="#c3b5a9" stroke-opacity=".6" stroke-width="1.5" stroke-linejoin="round"/>
    <path d="M192 62c6 6 9 14 9 22M204 50c9 9 15 21 15 34M216 38c13 13 20 30 20 47" stroke="#9c3340" stroke-width="1.5" stroke-linecap="round"/>
  </svg>`,
];
const nn = ['01', '02', '03'];
---

<section id="services" class="sec-line relative">
  <span class="ghost-num" aria-hidden="true">01</span>
  <div class="mx-auto max-w-5xl px-6 py-24 md:py-28">
    <p data-reveal class="kicker-rule font-mono text-[13px] uppercase tracking-[0.22em] text-bone">
      <span class="mr-3 text-accent-txt">01</span>{band.kicker}
    </p>

    <div data-reveal-stagger class="grid-12 mt-14">
      {band.cards.map((c, i) => (
        <article class="svc-card col-span-12 flex flex-col rounded-[var(--radius-card)] p-6 pt-7 sm:col-span-6 lg:col-span-4">
          <div class="mb-5 h-[118px] [&_svg]:mx-auto [&_svg]:h-full [&_svg]:w-auto" set:html={glyphs[i]} />
          <p class="font-mono text-[12.5px] uppercase tracking-[0.2em] text-accent-txt">{nn[i]} · {c.cat}</p>
          <h3 class="mt-3 font-display text-[27px] font-[550] leading-[1.14] text-bone">
            {c.pre} <em class="font-[420] italic text-accent-lg">{c.accent}</em>
          </h3>
          <p class="mt-3 text-[16px] leading-relaxed text-text-muted">{c.desc}</p>
          <p class="mt-auto pt-6">
            <a href="#work" class="link-draw inline-flex min-h-11 items-end font-mono text-[14px] text-accent-txt transition-colors hover:text-bone">{c.ref}</a>
          </p>
        </article>
      ))}
    </div>

    <div data-reveal class="mt-12 flex justify-center">
      <a href="#contact" class="link-draw inline-flex min-h-11 items-center font-mono text-[16px] text-accent-txt transition-colors hover:text-bone">{band.cta}</a>
    </div>
  </div>
</section>
