---
import { ui, servicesCta, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const ns = ['01', '02', '03', '04'];
const tags = [
  ['Twilio', 'ElevenLabs', 'Deepgram', 'GPT-4o'],
  ['Next.js', 'Supabase', 'Stripe', 'Cloudflare R2'],
  ['Python', 'FastAPI', 'Claude API', 'Playwright'],
  ['PyTorch', 'TensorFlow', 'RAVE', 'Essentia'],
];
// each capability links to a representative live project
const links = [
  'https://dance-voice-agent-dashboard.vercel.app',
  'https://ffinnico.netlify.app',
  'https://company-brain-alberto.onrender.com',
  'https://beyond-space-kappa.vercel.app',
];
---

<section id="services" class="border-t border-bone/10">
  <div class="mx-auto max-w-5xl px-6 py-20 md:py-24">
    <p class="font-mono text-[13px] uppercase tracking-[0.22em] text-oxblood-soft"><span class="mr-3">01</span>{t.services_title}</p>
    <p class="mt-3 max-w-2xl font-display text-2xl leading-snug text-bone md:text-[28px]">{t.services_lead}</p>

    <div class="mt-10 grid gap-x-10 gap-y-9 sm:grid-cols-2">
      {t.services.map((s, i) => (
        <div class="border-t border-bone/10 pt-5">
          <div class="flex items-baseline gap-3">
            <span class="font-mono text-[12px] text-text-dim">{ns[i]}</span>
            <h3 class="font-display text-xl font-semibold text-bone">{s.title}</h3>
          </div>
          <p class="mt-2 text-[15px] leading-relaxed text-text-muted">{s.desc}</p>
          <p class="mt-3 font-mono text-[12px] text-text-dim">{tags[i].join(' · ')}</p>
          <a
            href={links[i]}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-3 inline-block font-mono text-[12px] text-oxblood-soft underline-offset-4 transition hover:text-bone hover:underline"
          >
            {servicesCta[lang]}
          </a>
        </div>
      ))}
    </div>
  </div>
</section>
