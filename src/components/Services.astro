---
import { servicesBand, processSteps, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const band = servicesBand[lang];
const steps = processSteps[lang];
const stepsTitle = { en: 'how we work', it: 'come lavoro', es: 'cómo trabajo' }[lang];

// Lucide icons — one coherent family (24×24, stroke 1.8, currentColor set to
// oxblood by the .svc-ico tile). Sit in a rounded tile for presence.
const glyphs = [
  // 01 — app-window (sites & platforms)
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="2" y="4" width="20" height="16" rx="2"/><path d="M2 8h20"/><path d="M6 4v4"/><path d="M10 4v4"/>
  </svg>`,
  // 02 — workflow (automations & AI: things that talk to each other)
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <rect x="3" y="3" width="8" height="8" rx="2"/><path d="M7 11v4a2 2 0 0 0 2 2h4"/><rect x="13" y="13" width="8" height="8" rx="2"/>
  </svg>`,
  // 03 — audio-lines (voice agents — the brand wave motif)
  `<svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
    <path d="M2 10v3"/><path d="M6 6v11"/><path d="M10 3v18"/><path d="M14 8v7"/><path d="M18 5v13"/><path d="M22 10v3"/>
  </svg>`,
];
const nn = ['01', '02', '03'];
---

<section id="services" class="sec-line relative">
  <span class="ghost-num" aria-hidden="true">01</span>
  <div class="mx-auto max-w-5xl px-6 py-24 md:py-28">
    <p data-reveal class="kicker-rule font-mono text-[13px] uppercase tracking-[0.22em] text-bone">
      <span class="mr-3 text-accent-txt">01</span>{band.kicker}
    </p>

    <div data-reveal-stagger class="grid-12 mt-14">
      {band.cards.map((c, i) => (
        <article class="svc-card col-span-12 flex flex-col rounded-[var(--radius-card)] p-6 pt-7 sm:col-span-6 lg:col-span-4">
          <div class="svc-ico mb-6" set:html={glyphs[i]} />
          <p class="font-mono text-[12.5px] uppercase tracking-[0.2em] text-accent-txt">{nn[i]} · {c.cat}</p>
          <h3 class="mt-3 font-display text-[27px] font-[550] leading-[1.14] text-bone">
            {c.pre} <em class="font-[420] italic text-accent-lg">{c.accent}</em>
          </h3>
          <p class="mt-3 text-[16px] leading-relaxed text-text-muted">{c.desc}</p>
          <p class="mt-5">
            <a href="#work" class="link-draw inline-flex min-h-11 items-center font-mono text-[14px] text-accent-txt transition-colors hover:text-bone">{c.ref}</a>
          </p>
        </article>
      ))}
    </div>

    <!-- How we work — strip under the cards, before the CTA -->
    <div data-reveal class="mt-20 border-t border-bone/10 pt-12">
      <p class="font-mono text-[13px] uppercase tracking-[0.22em] text-accent-txt">{stepsTitle}</p>
      <ol data-reveal-stagger class="mt-8 grid grid-cols-1 gap-x-10 gap-y-8 sm:grid-cols-2 lg:grid-cols-4">
        {steps.map((s, i) => (
          <li class="border-l border-oxblood/40 pl-5">
            <p class="font-mono text-[13px] tracking-[0.18em] text-oxblood-soft">0{i + 1}</p>
            <h3 class="mt-2 font-display text-[21px] font-semibold leading-tight text-bone">{s.title}</h3>
            <p class="mt-1.5 text-[16px] leading-snug text-text-muted">{s.desc}</p>
          </li>
        ))}
      </ol>
    </div>

    <div data-reveal class="mt-12 flex justify-center">
      <a href="#contact" class="link-draw inline-flex min-h-11 items-center font-mono text-[16px] text-accent-txt transition-colors hover:text-bone">{band.cta}</a>
    </div>
  </div>
</section>
