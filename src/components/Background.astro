---
import { ui, experience, training, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const exp = experience[lang];
const tr = training[lang];

const VISIBLE = 2;
const moreLabel = { en: 'show more', it: 'mostra altri', es: 'ver más' }[lang];

const lists = [
  { id: 'exp', title: t.experience_title, items: exp },
  { id: 'train', title: t.training_title, items: tr },
];
---

<section id="experience" class="sec-line">
  <div class="mx-auto grid max-w-5xl gap-14 px-6 py-14 md:grid-cols-2 md:py-16">
    {lists.map((list) => (
      <div>
        <h2 data-reveal class="font-mono text-[13px] uppercase tracking-[0.22em] text-bone">{list.title}</h2>
        <ol class="mt-7 space-y-7" data-list={list.id} data-reveal-stagger>
          {list.items.map((e, i) => (
            <li
              class:list={['border-l border-oxblood/40 pl-5', i >= VISIBLE && 'is-extra']}
              style={i >= VISIBLE ? 'display:none' : undefined}
            >
              <h3 class="font-display text-lg font-semibold text-bone">{e.title}</h3>
              <p class="mt-0.5 font-mono text-[12px] text-text-dim">{e.meta}</p>
              <p class="mt-1.5 text-[15px] leading-relaxed text-text-muted">{e.desc}</p>
            </li>
          ))}
        </ol>
        {list.items.length > VISIBLE && (
          <button
            type="button"
            data-list={list.id}
            class="more-btn mt-5 font-mono text-[12px] text-text-muted underline-offset-4 transition hover:text-bone hover:underline"
          >
            {moreLabel} (+{list.items.length - VISIBLE})
          </button>
        )}
      </div>
    ))}
  </div>
</section>

<script>
  document.querySelectorAll('.more-btn').forEach((btn) => {
    btn.addEventListener('click', () => {
      const id = btn.getAttribute('data-list');
      document
        .querySelectorAll(`ol[data-list="${id}"] .is-extra`)
        .forEach((el) => ((el as HTMLElement).style.display = ''));
      (btn as HTMLElement).style.display = 'none';
    });
  });
</script>
