---
import WaveSignature from './WaveSignature.astro';
import { ui, contactReply, contactHeadline, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const headline = contactHeadline[lang];
---

<section id="contact" class="relative overflow-hidden border-t border-bone/10 bg-ink-2">
  <WaveSignature />
  <div class="relative z-10 mx-auto max-w-5xl px-6 py-24 md:py-32">
    <h2 class="font-mono text-[12px] uppercase tracking-[0.2em] text-text-muted">
      <span class="mr-3 text-text-dim">04</span>{t.contact_title}
    </h2>
    <p class="mt-6 font-display text-5xl font-semibold leading-[1.02] tracking-tight text-bone md:text-7xl xl:text-8xl">
      {headline.pre}<em class="italic text-oxblood-soft">{headline.accent}</em>
    </p>
    <p class="mt-6 max-w-xl text-[16px] leading-relaxed text-text-muted">{t.contact_lead}</p>
    <p class="mt-2 font-mono text-[13px] text-text-dim">{contactReply[lang]}</p>

    <div class="mt-9 flex flex-wrap items-center gap-3">
      <a
        href="mailto:ing.albedimaria@gmail.com"
        class="rounded-[var(--radius-btn)] bg-bone px-6 py-3.5 font-mono text-[15px] font-medium text-ink transition hover:opacity-90"
      >
        {t.contact_email}
      </a>
      <a
        href="https://www.linkedin.com/in/di-maria-alberto/"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-[var(--radius-btn)] border border-bone/25 px-5 py-3.5 font-mono text-[14px] text-bone transition hover:border-bone/60"
      >
        LinkedIn ↗
      </a>
      <a
        href="https://github.com/albedimaria"
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-[var(--radius-btn)] border border-bone/15 px-5 py-3.5 font-mono text-[14px] text-text-muted transition hover:text-bone"
      >
        GitHub ↗
      </a>
      <a
        href="/cv.pdf"
        class="rounded-[var(--radius-btn)] border border-bone/15 px-5 py-3.5 font-mono text-[14px] text-text-muted transition hover:text-bone"
      >
        {t.hero_cta_cv} ↓
      </a>
    </div>
  </div>
</section>
