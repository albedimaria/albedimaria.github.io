---
import WaveSignature from './WaveSignature.astro';
import { ui, contactReply, contactHeadline, contactForm, budgetField, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const headline = contactHeadline[lang];
const f = contactForm[lang];
const budget = budgetField[lang];

// Web3Forms access key — free, tied to Alberto's inbox. Static-site friendly:
// the form posts to Web3Forms and the reply lands in the linked email. Swap the
// placeholder with the real key (https://web3forms.com → enter email → get key).
const WEB3FORMS_KEY = '730cfe53-7f78-4bb5-90cf-ee5be2bae7c7';

// Inline-validation messages + a low-friction trust line under the copy.
const fErr: Record<Lang, { name: string; email: string; message: string }> = {
  en: { name: 'Your name?', email: 'A valid email, please', message: 'A line or two?' },
  it: { name: 'Il tuo nome?', email: 'Un’email valida, per favore', message: 'Due righe?' },
  es: { name: '¿Tu nombre?', email: 'Un email válido, por favor', message: '¿Dos líneas?' },
};
const e = fErr[lang];
const freeCall: Record<Lang, string> = {
  en: 'First call is free',
  it: 'Prima chiamata gratuita',
  es: 'Primera llamada gratis',
};
---

<section id="contact" class="sec-line relative overflow-hidden bg-ink-2">
  <span class="ghost-num" aria-hidden="true">04</span>
  <WaveSignature top="74%" opacity={0.5} />
  <div data-reveal-stagger class="relative z-10 mx-auto grid max-w-5xl gap-x-16 gap-y-12 px-6 py-24 md:py-32 lg:grid-cols-[1fr_minmax(0,440px)]">
    <div class="min-w-0">
      <p class="font-mono text-[13px] uppercase tracking-[0.22em] text-bone">
        <span class="mr-3 text-oxblood-soft">04</span>{t.contact_title}
      </p>
      <p class="mt-6 font-display text-5xl font-semibold leading-[1.02] tracking-tight text-bone md:text-7xl xl:text-8xl">
        {headline.pre}<em class="italic text-accent-lg">{headline.accent}</em>
      </p>
      <p class="mt-6 max-w-xl text-[16px] leading-relaxed text-text-muted">{t.contact_lead}</p>
      <p class="mt-2 font-mono text-[13px] text-text-dim">{contactReply[lang]}</p>

      <div class="mt-8 inline-flex items-center gap-2.5 rounded-[var(--radius-btn)] border border-bone/12 bg-ink/40 px-4 py-3 font-mono text-[13px] text-text-muted">
        <span class="h-2 w-2 flex-none rounded-full bg-[#57c98a]" aria-hidden="true"></span>
        {freeCall[lang]}
      </div>
    </div>

    <!-- Contact form — no-JS fallback: posts straight to Web3Forms. With JS the
         inline script intercepts and shows status without leaving the page. -->
    <form
      id="contact-form"
      action="https://api.web3forms.com/submit"
      method="POST"
      class="min-w-0 lg:self-end"
    >
      <input type="hidden" name="access_key" value={WEB3FORMS_KEY} />
      <input type="hidden" name="subject" value="New message from albedimaria.github.io" />
      <input type="hidden" name="from_name" value="Portfolio · D10S" />
      <!-- honeypot: bots fill it, humans never see it -->
      <input type="checkbox" name="botcheck" class="hidden" style="display:none" tabindex="-1" autocomplete="off" aria-hidden="true" />

      <div class="grid gap-4 sm:grid-cols-2">
        <label class="block">
          <span class="mb-1.5 block font-mono text-[12px] uppercase tracking-wider text-text-muted">{f.name}</span>
          <input
            type="text"
            name="name"
            required
            placeholder={f.namePh}
            data-err-msg={e.name}
            aria-describedby="err-name"
            class="contact-input w-full rounded-[var(--radius-btn)] border border-bone/15 bg-transparent px-4 py-3 font-mono text-[14px] text-bone placeholder:text-text-dim focus:border-oxblood focus:outline-none"
          />
          <span id="err-name" class="ferr" data-err aria-live="polite"></span>
        </label>
        <label class="block">
          <span class="mb-1.5 block font-mono text-[12px] uppercase tracking-wider text-text-muted">{f.email}</span>
          <input
            type="email"
            name="email"
            required
            placeholder={f.emailPh}
            autocomplete="email"
            data-err-msg={e.email}
            aria-describedby="err-email"
            class="contact-input w-full rounded-[var(--radius-btn)] border border-bone/15 bg-transparent px-4 py-3 font-mono text-[14px] text-bone placeholder:text-text-dim focus:border-oxblood focus:outline-none"
          />
          <span id="err-email" class="ferr" data-err aria-live="polite"></span>
        </label>
      </div>

      <label class="mt-4 block">
        <span class="mb-1.5 block font-mono text-[12px] uppercase tracking-wider text-text-muted">
          {budget.label} <span class="normal-case text-text-dim">· {budget.optional}</span>
        </span>
        <select
          name="budget"
          class="w-full appearance-none rounded-[var(--radius-btn)] border border-bone/15 bg-transparent px-4 py-3 font-mono text-[14px] text-bone focus:border-oxblood focus:outline-none [&>option]:bg-surface"
        >
          <option value="">{budget.placeholder}</option>
          {budget.options.map((o) => <option value={o}>{o}</option>)}
        </select>
      </label>

      <label class="mt-4 block">
        <span class="mb-1.5 block font-mono text-[12px] uppercase tracking-wider text-text-muted">{f.message}</span>
        <textarea
          name="message"
          required
          rows="4"
          placeholder={f.messagePh}
          data-err-msg={e.message}
          aria-describedby="err-message"
          class="contact-input w-full resize-y rounded-[var(--radius-btn)] border border-bone/15 bg-transparent px-4 py-3 font-mono text-[14px] leading-relaxed text-bone placeholder:text-text-dim focus:border-oxblood focus:outline-none"
        ></textarea>
        <span id="err-message" class="ferr" data-err aria-live="polite"></span>
      </label>

      <div class="mt-5 flex flex-wrap items-center gap-4">
        <button
          type="submit"
          data-send={f.send}
          data-sending={f.sending}
          class="btn-primary disabled:opacity-60"
        >
          {f.send}
        </button>
        <a href="mailto:ing.albedimaria@gmail.com" class="link-draw font-mono text-[13px] text-text-muted transition hover:text-bone">
          {f.orEmail}
        </a>
      </div>

      <p
        id="contact-status"
        role="status"
        aria-live="polite"
        class="mt-4 hidden font-mono text-[13px]"
        data-success={f.success}
        data-error={f.error}
      ></p>
    </form>
  </div>
</section>

<script>
  const form = document.getElementById('contact-form') as HTMLFormElement | null;
  const status = document.getElementById('contact-status');
  if (form && status) {
    const btn = form.querySelector('button[type="submit"]') as HTMLButtonElement;
    const label = btn.dataset.send!;
    const sending = btn.dataset.sending!;
    form.addEventListener('submit', async (e) => {
      e.preventDefault();
      btn.disabled = true;
      btn.textContent = sending;
      status.classList.add('hidden');
      try {
        const res = await fetch(form.action, {
          method: 'POST',
          headers: { Accept: 'application/json' },
          body: new FormData(form),
        });
        const ok = res.ok;
        status.textContent = ok ? '✓ ' + status.dataset.success! : status.dataset.error!;
        status.classList.remove('hidden');
        status.classList.toggle('is-ok', ok);
        status.style.color = ok ? 'var(--color-bone)' : 'var(--color-accent-txt)';
        if (ok) form.reset();
      } catch {
        status.textContent = status.dataset.error!;
        status.classList.remove('hidden');
        status.style.color = 'var(--color-oxblood-soft)';
      } finally {
        btn.disabled = false;
        btn.textContent = label;
      }
    });

    // Inline validation — checks on blur, clears as the user fixes it.
    const rules: Record<string, (v: string) => boolean> = {
      name: (v) => v.trim().length > 0,
      email: (v) => /^[^@\s]+@[^@\s]+\.[^@\s]+$/.test(v.trim()),
      message: (v) => v.trim().length >= 4,
    };
    (['name', 'email', 'message'] as const).forEach((n) => {
      const input = form.elements.namedItem(n) as HTMLInputElement | HTMLTextAreaElement | null;
      if (!input) return;
      const err = document.getElementById(`err-${n}`);
      const check = () => {
        const bad = input.value.length > 0 && !rules[n](input.value);
        const empty = input.value.trim().length === 0;
        const show = bad || empty;
        if (err) err.textContent = show ? (input.dataset.errMsg || '') : '';
        input.classList.toggle('is-invalid', show);
        input.setAttribute('aria-invalid', show ? 'true' : 'false');
      };
      input.addEventListener('blur', check);
      input.addEventListener('input', () => {
        if (input.classList.contains('is-invalid') && rules[n](input.value)) {
          if (err) err.textContent = '';
          input.classList.remove('is-invalid');
          input.setAttribute('aria-invalid', 'false');
        }
      });
    });
  }
</script>
