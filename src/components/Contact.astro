---
import WaveSignature from './WaveSignature.astro';
import { ui, contactReply, contactHeadline, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const headline = contactHeadline[lang];
---

<section id="contact" class="relative overflow-hidden border-t border-bone/10 bg-ink-2">
  <WaveSignature />
  <div class="relative z-10 mx-auto max-w-5xl px-6 py-24 md:py-32">
    <p class="font-mono text-[13px] uppercase tracking-[0.22em] text-bone">
      <span class="mr-3 text-oxblood-soft">04</span>{t.contact_title}
    </p>
    <p class="mt-6 font-display text-5xl font-semibold leading-[1.02] tracking-tight text-bone md:text-7xl xl:text-8xl">
      {headline.pre}<em class="italic text-oxblood-soft">{headline.accent}</em>
    </p>
    <p class="mt-6 max-w-xl text-[16px] leading-relaxed text-text-muted">{t.contact_lead}</p>
    <p class="mt-2 font-mono text-[13px] text-text-dim">{contactReply[lang]}</p>

    <div class="mt-9 flex flex-wrap items-center gap-3">
      <a
        href="mailto:ing.albedimaria@gmail.com"
        class="rounded-[var(--radius-btn)] bg-bone px-7 py-4 font-mono text-[15px] font-medium text-ink transition hover:opacity-90"
      >
        {t.contact_email}
      </a>
      <!-- room for a second CTA later (e.g. book a call / Calendly) -->
    </div>
  </div>
</section>
