---
import { agentBand, voiceUi, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const band = agentBand[lang];
const vu = voiceUi[lang];
const [titleA, titleB] = band.title.split('\n');
---

<!-- D10S live-agent band — full width under the hero. The panel is a static
     shell (zero JS) that mounts the ~680 KB React + ElevenLabs island only on
     the first click (boot script below). -->
<section id="agent-demo" class="sec-line bg-ink-2">
  <div class="mx-auto grid-12 max-w-5xl items-center px-6 py-[76px]">
    <div class="col-span-12 md:col-span-7">
      <p class="kicker-rule font-mono text-[13px] uppercase tracking-[0.22em] text-bone">{band.kicker}</p>
      <h2 class="mt-4 font-display text-[clamp(26px,3.2vw,38px)] font-[550] leading-[1.14] text-bone">
        {titleA}<br />{titleB}
      </h2>
      <p class="mt-3.5 max-w-[30ch] text-[16px] leading-relaxed text-text-muted">{band.desc}</p>
    </div>

    <div class="col-span-12 mt-8 md:col-span-5 md:col-start-8 md:mt-0">
      <div
        id="d10s-panel"
        data-lang={lang}
        class="rounded-[var(--radius-card)] border border-bone/10 bg-surface p-5 shadow-[0_0_50px_rgba(0,0,0,0.4)]"
      >
        <div class="space-y-3">
          <div class="flex items-center gap-2 px-1 pb-1">
            <span class="h-1.5 w-1.5 rounded-full bg-oxblood-soft motion-safe:animate-pulse" aria-hidden="true"></span>
            <span class="font-mono text-[12px] uppercase tracking-[0.18em] text-text-dim">D10S · online</span>
          </div>
          <div class="flex flex-wrap items-center justify-center gap-2.5">
            <button
              type="button"
              data-d10s="voice"
              class="flex min-h-11 items-center gap-2 rounded-full bg-oxblood px-6 py-2.5 font-mono text-[13px] uppercase tracking-[0.15em] text-[#f6dfe4] transition hover:bg-oxblood/85"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                <rect x="9" y="3" width="6" height="11" rx="3" /><path d="M5 11a7 7 0 0 0 14 0" /><path d="M12 18v3" />
              </svg>
              {vu.talk}
            </button>
            <button
              type="button"
              data-d10s="text"
              class="flex min-h-11 items-center gap-2 rounded-full border border-bone/35 px-5 py-2.5 font-mono text-[13px] uppercase tracking-[0.15em] text-text-muted transition hover:border-bone/60 hover:text-bone"
            >
              <svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
                <rect x="3" y="7" width="18" height="11" rx="2" /><path d="M7 11h.01M11 11h.01M15 11h.01M17 11h.01M7 15h10" />
              </svg>
              {vu.type}
            </button>
          </div>
          <div class="flex flex-wrap justify-center gap-2 pt-0.5">
            {vu.chips.map((c) => (
              <button
                type="button"
                data-d10s="chip"
                data-chip={c}
                class="min-h-11 rounded-full border border-bone/12 bg-bone/[0.04] px-3 py-1.5 font-mono text-[12px] text-text-muted transition hover:border-oxblood-soft/60 hover:text-bone"
              >
                {c}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>

  <script>
    // Load the voice SDK only on the first interaction with the panel.
    const panel = document.getElementById('d10s-panel');
    if (panel) {
      let booted = false;
      const boot = async (btn: HTMLElement) => {
        if (booted) return;
        booted = true;
        const action = btn.dataset.d10s === 'chip' ? btn.dataset.chip! : btn.dataset.d10s!;
        const { mount } = await import('./voice-mount');
        mount(panel, (panel.dataset.lang as 'en' | 'it' | 'es') || 'en', action);
      };
      panel.querySelectorAll<HTMLElement>('[data-d10s]').forEach((b) =>
        b.addEventListener('click', () => boot(b))
      );
    }
  </script>
</section>
