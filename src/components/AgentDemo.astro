---
import { agentBand, voiceUi, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const band = agentBand[lang];
const vu = voiceUi[lang];

// Concept A — the panel IS the section. One centered column, the live agent as
// the focal object. Headline is a statement (not a question), the greeting lives
// only inside the panel: no duplicated copy, no stacked questions.
const headline: Record<Lang, string> = {
  en: 'Ask my agent.',
  it: 'Chiedi al mio agente.',
  es: 'Pregunta a mi agente.',
};
const greeting: Record<Lang, string> = {
  en: 'Hi, I’m D10S. Tell me what you need.',
  it: 'Ciao, sono D10S. Dimmi di cosa hai bisogno.',
  es: 'Hola, soy D10S. Dime qué necesitas.',
};
const tryLabel: Record<Lang, string> = { en: 'try asking', it: 'prova a chiedere', es: 'prueba a preguntar' };
const inputPh: Record<Lang, string> = { en: 'type a message…', it: 'scrivi un messaggio…', es: 'escribe un mensaje…' };
const micLabel: Record<Lang, string> = { en: 'Talk to D10S', it: 'Parla con D10S', es: 'Habla con D10S' };
const minLabel: Record<Lang, string> = { en: 'Minimise D10S', it: 'Riduci D10S', es: 'Reducir D10S' };
---

<!-- D10S live-agent band — full width under the hero. The panel is a static
     shell (zero JS) that mounts the ~680 KB React + ElevenLabs island only on
     the first interaction (boot script below). -->
<!-- Fills the viewport MINUS the sticky nav (77px, in flow), and reserves the
     same 77px as scroll-margin: the hero cue is a plain #anchor, so without it
     the section top lands under the nav and the kicker sits glued to it. With
     both, landing here shows the section framed, with no leftover band of the
     next one. -->
<section id="agent-demo" class="sec-line flex min-h-[calc(100svh-77px)] scroll-mt-[77px] items-center bg-ink-2">
  <div class="mx-auto w-full max-w-2xl px-6 py-16 text-center">
    <p data-reveal class="kicker-rule kicker-center font-mono text-[13px] uppercase tracking-[0.22em] text-bone">{band.kicker}</p>
    <h2 data-reveal class="mx-auto mt-5 max-w-[16ch] font-display text-[clamp(30px,4.4vw,46px)] font-[550] leading-[1.06] tracking-[-0.01em] text-bone">
      {headline[lang]}
    </h2>

    <!-- The wrapper is what detaches: when the section leaves the viewport and
         a conversation is running, it goes position:fixed into the corner. Same
         DOM node throughout — React never unmounts, so the ElevenLabs session,
         the mic grant and the transcript survive the move. -->
    <div data-reveal id="d10s-wrap" class="d10s-wrap mt-9">
      <button id="d10s-min" type="button" class="d10s-min" aria-label={minLabel[lang]}>
        <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12M18 6L6 18" />
        </svg>
      </button>
      <div id="d10s-panel" data-lang={lang} class="d10s d10s-solo text-left">
      <div class="d10s-bar"><span class="d10s-live" aria-hidden="true"></span><span><b>D10S</b> · online</span></div>

      <p class="d10s-say" data-typewriter>{greeting[lang]}</p>

      <div class="d10s-sugg">
        <div class="lb">{tryLabel[lang]}</div>
        {vu.chips.map((c) => (
          <button type="button" data-d10s="chip" data-chip={c}>{c}</button>
        ))}
      </div>

      <div class="d10s-input">
        <button type="button" class="d10s-input-text" data-d10s="text" aria-label={inputPh[lang]}>{inputPh[lang]}</button>
        <button type="button" class="d10s-mic" data-d10s="voice" aria-label={micLabel[lang]}>
          <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
            <rect x="9" y="3" width="6" height="11" rx="3" /><path d="M5 11a7 7 0 0 0 14 0" /><path d="M12 18v3" />
          </svg>
        </button>
      </div>
      </div>
    </div>
  </div>

  <script>
    // Load the voice SDK only on the first interaction with the panel.
    const panel = document.getElementById('d10s-panel');
    const wrap = document.getElementById('d10s-wrap');
    const section = document.getElementById('agent-demo');
    if (panel && wrap && section) {
      let booted = false;
      const boot = async (action: string | null) => {
        if (booted) return;
        booted = true;
        const { mount } = await import('./voice-mount');
        mount(panel, (panel.dataset.lang as 'en' | 'it' | 'es') || 'en', action);
        sync();
      };
      panel.querySelectorAll<HTMLElement>('[data-d10s]').forEach((b) =>
        b.addEventListener('click', () =>
          boot(b.dataset.d10s === 'chip' ? b.dataset.chip! : b.dataset.d10s!)
        )
      );

      /* ----------------------------------------------------------------
         Dock orchestration. One panel, two homes.

         In the section  → the big panel, as before.
         Scrolled past it, with a live conversation → the SAME element goes
         fixed into the corner and keeps talking; the site stays fully visible
         behind it, because the whole point is watching the agent move the
         carousel and fill the form while it speaks.

         The seal (D10SDock) and the panel are mutually exclusive: whichever is
         showing, the other is not.
      ---------------------------------------------------------------- */
      const dock = document.getElementById('d10s-dock');
      const minBtn = document.getElementById('d10s-min');
      let past = false; // scrolled BELOW the agent section
      let open = false; // corner panel expanded — NEVER by itself, only on click

      const sync = () => {
        const showCorner = booted && past && open;
        wrap.classList.toggle('is-docked', showCorner);
        // seal and corner panel are mutually exclusive
        dock?.classList.toggle('is-on', past && !showCorner);
        dock?.classList.toggle('is-live', booted && !open);
        // the back-to-top arrow would collide with a docked panel
        document.body.classList.toggle('d10s-docked', showCorner);
      };

      let ticking = false;
      const measure = () => {
        ticking = false;
        const r = section.getBoundingClientRect();
        const now = r.bottom < window.innerHeight * 0.6;
        if (now === past) return;
        past = now;
        // Leaving the section never pops the panel open on its own: the seal is
        // the resting state. Coming back in, the panel is home again anyway.
        open = false;
        sync();
      };
      const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(measure); } };
      window.addEventListener('scroll', onScroll, { passive: true });
      window.addEventListener('resize', onScroll, { passive: true });
      measure();
      sync();

      // Seal click: open the agent RIGHT HERE. It must not drag the visitor
      // back up the page — that was the whole complaint.
      dock?.addEventListener('click', () => {
        open = true;
        if (!booted) boot(null);
        else sync();
      });
      minBtn?.addEventListener('click', () => { open = false; sync(); });

      // Light dismiss: a small floating panel closes when you click away from it
      // or press Escape. The click that OPENED it bubbles up here too, hence the
      // #d10s-dock guard — without it the panel would close on its own opening.
      document.addEventListener('click', (e) => {
        if (!open) return;
        const el = e.target as HTMLElement;
        if (el.closest('#d10s-wrap') || el.closest('#d10s-dock')) return;
        open = false;
        sync();
      });
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && open) { open = false; sync(); }
      });

      // On a phone the seal sits ON the contact form. Once Contatti is on screen
      // the visitor has arrived where the agent was taking him, so the seal steps
      // aside (CSS hides it under 768px only — on desktop it covers nothing, and
      // it is the one entry point from which D10S can pre-fill the form).
      const contact = document.getElementById('contact');
      if (contact) {
        new IntersectionObserver(
          ([e]) => document.body.classList.toggle('contact-in-view', e.isIntersecting),
          { threshold: 0.22 }
        ).observe(contact);
      }

      // Idle liveness — D10S "types" its greeting once, the first time the
      // panel scrolls into view. Any interaction (or reduced-motion) reveals
      // the full text immediately.
      const say = panel.querySelector<HTMLElement>('[data-typewriter]');
      const reduce = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
      if (say && !reduce) {
        const full = say.textContent || '';
        let done = false;
        const finish = () => { if (done) return; done = true; say.textContent = full; say.classList.remove('is-typing'); };
        panel.querySelectorAll<HTMLElement>('[data-d10s]').forEach((b) => b.addEventListener('click', finish));
        const io = new IntersectionObserver((entries) => {
          entries.forEach((e) => {
            if (!e.isIntersecting || done) return;
            io.unobserve(e.target);
            // Reserve the final height so typing doesn't shift the panel (CLS).
            say.style.minHeight = say.offsetHeight + 'px';
            say.textContent = '';
            say.classList.add('is-typing');
            let i = 0;
            const tick = () => {
              if (done) return;
              say.textContent = full.slice(0, ++i);
              if (i < full.length) setTimeout(tick, 22);
              else { say.classList.remove('is-typing'); done = true; }
            };
            tick();
          });
        }, { threshold: 0.5 });
        io.observe(panel);
      }
    }
  </script>
</section>
