---
import { projects } from '../data/projects';
import ProjectCard from './ProjectCard.astro';
import { ui, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

// Display order: commissioned first (default set), then All, then the rest.
const filterOrder = ['Client work', 'All', 'Hackathons', 'Voice AI', 'Audio / ML', 'Research'] as const;
const DEFAULT_FILTER = 'Client work';
const hint: Record<Lang, string> = {
  en: 'browse projects ‹ › — the page stays put',
  it: 'scorri i progetti ‹ › — la pagina resta ferma',
  es: 'navega los proyectos ‹ › — la página no se mueve',
};
const navLabel: Record<Lang, string> = { en: 'Projects, one at a time', it: 'Progetti, uno alla volta', es: 'Proyectos, uno a la vez' };
const prevLabel: Record<Lang, string> = { en: 'Previous project', it: 'Progetto precedente', es: 'Proyecto anterior' };
const nextLabel: Record<Lang, string> = { en: 'Next project', it: 'Progetto successivo', es: 'Proyecto siguiente' };
---

<section id="work" class="sec-line relative bg-ink-2">
  <span class="ghost-num" aria-hidden="true">02</span>
  <div class="mx-auto max-w-5xl px-6 py-14 md:py-24">
    <p data-reveal class="font-mono text-[13px] uppercase tracking-[0.22em] text-bone"><span class="mr-3 text-oxblood-soft">02</span>{t.work_title}</p>
    <h2 data-reveal class="mt-4 max-w-2xl font-display text-3xl leading-snug text-bone md:text-4xl">{t.work_lead}</h2>

    <div data-reveal class="mt-8 flex flex-wrap items-center gap-x-2 gap-y-3">
      {filterOrder.map((f) => (
        <button
          type="button"
          data-filter={f}
          data-desc={t.filter_desc[f]}
          aria-pressed={f === DEFAULT_FILTER ? 'true' : 'false'}
          class:list={['filter-chip', f === DEFAULT_FILTER && 'is-on']}
        >
          {t.filter_labels[f]}
        </button>
      ))}
      <span id="filter-desc" class="w-full font-mono text-[12px] uppercase tracking-[0.08em] text-text-dim md:ml-auto md:w-auto md:self-center"></span>
    </div>

    <div
      class="pstage"
      data-reveal
      tabindex="0"
      role="region"
      aria-roledescription="carousel"
      aria-label={navLabel[lang]}
    >
      <div class="ws-controls">
        <span class="ws-count" aria-hidden="true"></span>
        <div class="ws-arrows">
          <button type="button" class="ws-arrow ws-prev" aria-label={prevLabel[lang]}>‹</button>
          <button type="button" class="ws-arrow ws-next" aria-label={nextLabel[lang]}>›</button>
        </div>
      </div>

      <div class="ws-track">
        {projects.map((p) => <ProjectCard project={p} lang={lang} />)}
      </div>

      <div class="ws-dots" role="tablist" aria-label={navLabel[lang]}></div>
      <p class="ws-live" aria-live="polite"></p>
    </div>

    <p class="ws-hint" aria-hidden="true">{hint[lang]}</p>
  </div>
</section>

<script>
  const stage = document.querySelector('.pstage') as HTMLElement | null;
  if (stage) {
    const slides = Array.from(stage.querySelectorAll('.pslide')) as HTMLElement[];
    const chips = Array.from(document.querySelectorAll('.filter-chip')) as HTMLElement[];
    const counter = stage.querySelector('.ws-count') as HTMLElement;
    const prevBtn = stage.querySelector('.ws-prev') as HTMLButtonElement;
    const nextBtn = stage.querySelector('.ws-next') as HTMLButtonElement;
    const dotsWrap = stage.querySelector('.ws-dots') as HTMLElement;
    const live = stage.querySelector('.ws-live') as HTMLElement;
    const filterDesc = document.getElementById('filter-desc');

    let filter = 'Client work';
    let set: HTMLElement[] = [];
    let pos = 0;

    const inFilter = (s: HTMLElement) =>
      filter === 'All' || (s.dataset.filters || '').split('|').includes(filter);

    function computeSet() {
      set = slides.filter(inFilter);
      if (pos >= set.length) pos = 0;
    }

    function render(dir = 0) {
      slides.forEach((s) => {
        s.hidden = true;
        s.classList.remove('is-active');
      });
      if (!set.length) {
        counter.textContent = '';
        dotsWrap.innerHTML = '';
        return;
      }
      const active = set[pos];
      active.hidden = false;
      // Directional entrance — new slide enters from the side you're heading to.
      active.style.setProperty('--slide-from', dir > 0 ? '36px' : dir < 0 ? '-36px' : '0px');
      active.classList.add('is-active');

      counter.innerHTML = `<b>${String(pos + 1).padStart(2, '0')}</b> / ${String(set.length).padStart(2, '0')}`;

      dotsWrap.innerHTML = '';
      set.forEach((_, i) => {
        const d = document.createElement('button');
        d.type = 'button';
        d.className = 'ws-dot' + (i === pos ? ' on' : '');
        d.setAttribute('role', 'tab');
        d.setAttribute('aria-selected', String(i === pos));
        d.setAttribute('aria-label', `${i + 1} / ${set.length}`);
        d.addEventListener('click', () => { const dir = i > pos ? 1 : i < pos ? -1 : 0; pos = i; render(dir); });
        dotsWrap.appendChild(d);
      });

      const single = set.length <= 1;
      prevBtn.disabled = single;
      nextBtn.disabled = single;

      const title = active.querySelector('.ps-title')?.textContent?.trim() || '';
      live.textContent = `${pos + 1} / ${set.length} — ${title}`;
    }

    function go(delta: number) {
      if (set.length < 2) return;
      pos = (pos + delta + set.length) % set.length;
      render(delta);
    }

    prevBtn.addEventListener('click', () => go(-1));
    nextBtn.addEventListener('click', () => go(1));
    stage.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowLeft') { e.preventDefault(); go(-1); }
      else if (e.key === 'ArrowRight') { e.preventDefault(); go(1); }
    });

    // Touch swipe (mobile) — horizontal drag flips the project; ignore mostly
    // vertical moves so the page still scrolls.
    let tx = 0, ty = 0;
    stage.addEventListener('touchstart', (e) => { tx = e.touches[0].clientX; ty = e.touches[0].clientY; }, { passive: true });
    stage.addEventListener('touchend', (e) => {
      const dx = e.changedTouches[0].clientX - tx;
      const dy = e.changedTouches[0].clientY - ty;
      if (Math.abs(dx) > 44 && Math.abs(dx) > Math.abs(dy) * 1.5) go(dx < 0 ? 1 : -1);
    }, { passive: true });

    chips.forEach((chip) => {
      chip.addEventListener('click', () => {
        filter = chip.dataset.filter || 'All';
        chips.forEach((c) => {
          const on = c === chip;
          c.setAttribute('aria-pressed', String(on));
          c.classList.toggle('is-on', on);
        });
        if (filterDesc) filterDesc.textContent = chip.dataset.desc || '';
        pos = 0;
        computeSet();
        render();
      });
    });

    // Keep the D10S "take me to the projects" tool working: activate the
    // slide for a given project id, switching filter if needed.
    (window as any).workGoToProject = (id: string) => {
      const target = slides.find((s) => s.id === `proj-${id}`);
      if (!target) return;
      if (!inFilter(target)) {
        filter = 'All';
        chips.forEach((c) => {
          const on = c.dataset.filter === 'All';
          c.setAttribute('aria-pressed', String(on));
          c.classList.toggle('is-on', on);
        });
        if (filterDesc) filterDesc.textContent = '';
        computeSet();
      }
      const i = set.indexOf(target);
      if (i >= 0) { pos = i; render(); }
      stage.scrollIntoView({ behavior: 'smooth', block: 'center' });
      target.classList.add('proj-focus');
      setTimeout(() => target.classList.remove('proj-focus'), 2600);
    };

    // init
    const active = chips.find((c) => c.getAttribute('aria-pressed') === 'true');
    if (filterDesc && active) filterDesc.textContent = active.dataset.desc || '';
    computeSet();
    render();
  }
</script>
