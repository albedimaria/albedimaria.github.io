---
import type { Project } from '../data/projects';
import { frameLabelFor } from '../data/projects';

interface Props {
  project: Project;
}
const { project } = Astro.props;
const frameLabel = frameLabelFor(project);
---

<article
  data-filters={project.filters.join('|')}
  class="project-card group overflow-hidden rounded-[var(--radius-card)] border border-bone/10 bg-surface transition hover:border-oxblood/40"
>
  <div class="border-b border-oxblood/25">
    <div class="flex items-center gap-1.5 border-b border-bone/10 bg-ink-2 px-3 py-1.5">
      <span class="h-1.5 w-1.5 rounded-full bg-oxblood/70"></span>
      <span class="h-1.5 w-1.5 rounded-full bg-bone/15"></span>
      <span class="h-1.5 w-1.5 rounded-full bg-bone/15"></span>
      <span class="ml-2 truncate font-mono text-[10px] text-text-dim">{frameLabel}</span>
    </div>
    <div class="aspect-[16/9] w-full overflow-hidden bg-surface-2">
      <img
        src={project.cover}
        alt={`${project.title} preview`}
        loading="lazy"
        class="h-full w-full object-cover object-top transition duration-500 group-hover:scale-[1.03]"
      />
    </div>
  </div>
  <div class="p-5">
    <div class="flex items-baseline gap-2">
      <span class="font-mono text-[10px] uppercase tracking-wider text-text-muted">{project.category}</span>
      {project.badge && <span class="ml-auto font-mono text-[10px] text-oxblood-soft">{project.badge}</span>}
    </div>
    <h3 class="mt-1.5 font-display text-lg font-semibold text-bone">{project.title}</h3>
    <p class="mt-1 text-[12.5px] leading-snug text-text-muted">{project.oneliner}</p>
    {project.links.length > 0 && (
      <a
        href={project.links[0].href}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-3 inline-block font-mono text-[11px] text-text-dim transition hover:text-bone"
      >
        {project.links[0].label}
      </a>
    )}
  </div>
</article>
