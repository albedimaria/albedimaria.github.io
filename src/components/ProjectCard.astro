---
import type { Project } from '../data/projects';
import { frameLabelFor } from '../data/projects';
import { projectText } from '../i18n/project-text';
import type { Lang } from '../i18n/content';

interface Props {
  project: Project;
  index: number;
  extra?: boolean;
  lang: Lang;
}
const { project, index, extra = false, lang } = Astro.props;
const frameLabel = frameLabelFor(project);

const override = lang !== 'en' ? projectText[lang]?.[project.id] : undefined;
const oneliner = override?.oneliner ?? project.oneliner;
const bullets = override?.bullets ?? project.bullets;

// Only show the browser-window chrome (dots) when the label is a real host;
// otherwise render a neutral caption strip (no fake URL metaphor).
const looksLikeHost = /^[a-z0-9.-]+\.[a-z]{2,}$/i.test(frameLabel);

void index;
const imageLeft = false;
---

<article
  data-filters={project.filters.join('|')}
  data-extra={extra ? 'true' : 'false'}
  class:list={[
    'project-card grid gap-x-8 gap-y-5 rounded-[var(--radius-card)] border border-bone/10 bg-surface p-5 md:grid-cols-2 md:p-7',
    extra && 'is-extra',
  ]}
  style={extra ? 'display:none' : undefined}
>
  <div class:list={['min-w-0', imageLeft ? 'md:col-start-2 md:row-start-1' : 'md:col-start-1 md:row-start-1']}>
    <div class="flex items-baseline gap-3">
      <span class="font-mono text-[11px] uppercase tracking-wider text-text-muted">{project.category}</span>
      {project.badge && (
        <span class="ml-auto rounded-[4px] bg-oxblood px-2 py-0.5 font-mono text-[10px] font-medium tracking-wide text-[#f0d7dc]">
          {project.badge}
        </span>
      )}
    </div>
    <h3 class="mt-2 font-display text-2xl font-semibold text-bone md:text-[28px]">{project.title}</h3>
    <p class="mt-1.5 font-mono text-[13px] text-text-muted">{oneliner}</p>
  </div>

  <figure
    class:list={[
      'm-0 overflow-hidden rounded-[6px] border border-bone/10',
      imageLeft
        ? 'md:col-start-1 md:row-start-1 md:row-span-2 md:self-center'
        : 'md:col-start-2 md:row-start-1 md:row-span-2 md:self-center',
    ]}
  >
    <div class="flex items-center gap-1.5 border-b border-bone/10 bg-ink-2 px-3.5 py-2">
      {looksLikeHost && (
        <>
          <span class="h-2 w-2 rounded-full bg-oxblood/70"></span>
          <span class="h-2 w-2 rounded-full bg-bone/15"></span>
          <span class="h-2 w-2 rounded-full bg-bone/15"></span>
        </>
      )}
      <span class:list={['truncate font-mono text-[11px] text-text-dim', looksLikeHost && 'ml-2.5']}>{frameLabel}</span>
    </div>
    <div class="aspect-[16/10] w-full bg-surface-2">
      <img src={project.cover} alt={`${project.title} preview`} loading="lazy" class="h-full w-full object-contain object-top" />
    </div>
  </figure>

  <div class:list={['min-w-0', imageLeft ? 'md:col-start-2 md:row-start-2' : 'md:col-start-1 md:row-start-2']}>
    <ul class="space-y-2 text-[14px] leading-relaxed text-[#c8b9af]">
      {bullets.map((b) => (
        <li class="flex gap-2">
          <span class="text-oxblood-soft" aria-hidden="true">—</span>
          <span>{b}</span>
        </li>
      ))}
    </ul>
    <p class="mt-5 font-mono text-[11px] text-text-dim">
      <span class="text-oxblood-soft">stack</span>&nbsp;&nbsp;{project.stack.join(' · ')}
    </p>
    {project.engineering && (
      <details class="group mt-4 border-t border-bone/[0.08] pt-3">
        <summary class="flex cursor-pointer list-none items-center gap-x-2 font-mono text-[11px] text-text-dim [&::-webkit-details-marker]:hidden">
          <span class="text-oxblood-soft">engineering</span>
          <span class="text-text-muted">{project.engineering.summary}</span>
          <span class="ml-auto whitespace-nowrap text-oxblood-soft">
            <span class="group-open:hidden">show ↓</span>
            <span class="hidden group-open:inline">hide ↑</span>
          </span>
        </summary>
        <div class="mt-4 grid grid-cols-3 gap-x-3.5">
          {project.engineering.stats.map((s) => (
            <div class="border-l border-bone/10 pl-3.5 first:border-l-0 first:pl-0">
              <div class="font-display text-[22px] leading-none text-bone">{s.value}</div>
              <div class="mt-1.5 font-mono text-[9px] uppercase tracking-wide text-text-dim">{s.label}</div>
            </div>
          ))}
        </div>
        {project.engineering.note && (
          <p class="mt-3.5 font-mono text-[10px] leading-relaxed text-text-dim/70">{project.engineering.note}</p>
        )}
      </details>
    )}
    {project.links.length > 0 && (
      <div class="mt-5 flex flex-wrap gap-2.5">
        {project.links.map((l, i) => (
          <a
            href={l.href}
            target="_blank"
            rel="noopener noreferrer"
            class:list={[
              'rounded-[4px] px-3.5 py-2 font-mono text-[12px] transition',
              i === 0
                ? 'border border-oxblood text-bone hover:bg-oxblood/15'
                : 'border border-bone/15 text-text-muted hover:text-bone',
            ]}
          >
            {l.label}
          </a>
        ))}
      </div>
    )}
  </div>
</article>
