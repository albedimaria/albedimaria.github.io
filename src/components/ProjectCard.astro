---
import type { Project } from '../data/projects';
import { frameLabelFor } from '../data/projects';
import { projectText } from '../i18n/project-text';
import type { Lang } from '../i18n/content';

interface Props {
  project: Project;
  lang: Lang;
}
const { project, lang } = Astro.props;
const frameLabel = frameLabelFor(project);

const override = lang !== 'en' ? projectText[lang]?.[project.id] : undefined;
const oneliner = override?.oneliner ?? project.oneliner;
const bullets = override?.bullets ?? project.bullets;

// Only show the browser-window chrome (dots) when the label is a real host.
const looksLikeHost = /^[a-z0-9.-]+\.[a-z]{2,}$/i.test(frameLabel);
---

<article
  id={`proj-${project.id}`}
  data-filters={project.filters.join('|')}
  class="project-card pslide"
  aria-labelledby={`proj-${project.id}-title`}
>
  <!-- kicker (category) -->
  <div class="ps-top">
    <span class="ps-kick">{project.category}</span>
  </div>

  <!-- title + stamp + outcome, above the cover -->
  <div class="ps-headline">
    <div class="ps-titlerow">
      <h3 class="ps-title" id={`proj-${project.id}-title`}>{project.title}</h3>
      {project.badge && <span class="ps-stamp">{project.badge}</span>}
    </div>
    <p class="ps-outcome">{oneliner}</p>
  </div>

  <!-- LEFT: cover + visit-site  |  RIGHT: detail -->
  <div class="ps-grid">
    <div class="ps-left">
      <figure class="ps-cover">
        <div class="ps-bar">
          {looksLikeHost && (
            <>
              <span class="ps-dot ps-dot-a"></span>
              <span class="ps-dot ps-dot-b"></span>
              <span class="ps-dot ps-dot-b"></span>
            </>
          )}
          <span class:list={['ps-host', looksLikeHost && 'has-dots']}>{frameLabel}</span>
        </div>
        <div class="ps-well">
          <img src={project.cover} alt={`${project.title} — preview`} loading="lazy" />
        </div>
      </figure>

      {project.links.length > 0 && (
        <div class="ps-cta">
          {project.links.map((l) => (
            <a href={l.href} target="_blank" rel="noopener noreferrer" class="btn-ghost">{l.label}</a>
          ))}
        </div>
      )}

      {project.credit && (
        <p class="ps-credit">
          <span>{project.credit.role}</span>
          {project.credit.href
            ? <a href={project.credit.href} target="_blank" rel="noopener noreferrer">{project.credit.name} ↗</a>
            : project.credit.name}
        </p>
      )}
    </div>

    <div class="ps-detail">
      <ul class="ps-feats" role="list">
        {bullets.map((b, i) => (
          <li class="ps-feat">
            <span class="ps-n" aria-hidden="true">{String(i + 1).padStart(2, '0')}</span>
            {typeof b === 'string'
              ? <p>{b}</p>
              : <p><b>{b.lead}</b> — {b.body}</p>}
          </li>
        ))}
      </ul>

      <div class="ps-chips">
        {project.stack.map((s) => <span class="ps-chip">{s}</span>)}
        {project.ai?.map((s) => <span class="ps-chip is-ai">{s}</span>)}
        {project.hardware?.map((s) => <span class="ps-chip">{s}</span>)}
      </div>

      {project.engineering && (
        <details class="ps-rigor">
          <summary>
            <span class="ps-lab">engineering</span>
            <span>{project.engineering.summary}</span>
            <span class="ps-chev"><span class="c">apri&nbsp;↓</span><span class="o">chiudi&nbsp;↑</span></span>
          </summary>
          <div class="ps-stats">
            {project.engineering.stats.map((s) => (
              <div class="ps-stat">
                <div class="v">{s.value}</div>
                <div class="l">{s.label}</div>
              </div>
            ))}
          </div>
          {project.engineering.note && <p class="ps-note">{project.engineering.note}</p>}
        </details>
      )}
    </div>
  </div>
</article>
