---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Hero from './Hero.astro';
import Work from './Work.astro';
import Services from './Services.astro';
import About from './About.astro';
import Background from './Background.astro';
import Contact from './Contact.astro';
import BackToTop from './BackToTop.astro';
import { ui, voiceDemo, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const demo = voiceDemo[lang];
const talkToUrl = 'https://elevenlabs.io/app/talk-to?agent_id=agent_3401knpzvazqeamvd48kn8cn9gxe';
---

<Layout lang={lang}>
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <Work lang={lang} />
    <Services lang={lang} />
    <About lang={lang} />
    <Background lang={lang} />
    <Contact lang={lang} />

    <section class="border-t border-bone/10 bg-ink">
      <div class="mx-auto max-w-3xl px-6 py-16 text-center md:py-20">
        <a
          href={talkToUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="inline-block font-display text-2xl font-semibold text-bone transition hover:text-white md:text-3xl"
        >
          {demo.title}
        </a>
        <p class="mx-auto mt-3 max-w-md text-[14px] leading-relaxed text-text-muted">{demo.desc}</p>
      </div>
    </section>
  </main>

  <footer class="border-t border-bone/10 bg-ink">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-2 px-6 py-8 font-mono text-[11px] text-text-dim">
      <span>© 2026 Alberto Di Maria</span>
      <span>{t.footer_built}</span>
    </div>
  </footer>

  <BackToTop />
</Layout>
