---
import Layout from '../layouts/Layout.astro';
import Nav from './Nav.astro';
import Hero from './Hero.astro';
import AgentDemo from './AgentDemo.astro';
import Work from './Work.astro';
import Services from './Services.astro';
import About from './About.astro';
import Contact from './Contact.astro';
import BackToTop from './BackToTop.astro';
import D10SDock from './D10SDock.astro';
import { ui, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];
const navShortcuts: Record<Lang, string> = { en: 'Page shortcuts', it: 'Scorciatoie pagina', es: 'Atajos de página' };
---

<Layout lang={lang}>
  <Nav lang={lang} />
  <main>
    <Hero lang={lang} />
    <AgentDemo lang={lang} />
    <Services lang={lang} />
    <Work lang={lang} />
    <About lang={lang} />
    <Contact lang={lang} />
  </main>

  <footer class="border-t border-bone/10 bg-ink">
    <div class="mx-auto flex max-w-5xl flex-wrap items-center justify-between gap-2 px-6 py-8 font-mono text-[12px] text-text-dim">
      <span>© 2026 Alberto Di Maria</span>
      <span>{t.footer_built}</span>
    </div>
  </footer>

  <nav aria-label={navShortcuts[lang]}>
    <BackToTop />
    <D10SDock lang={lang} />
  </nav>
</Layout>
