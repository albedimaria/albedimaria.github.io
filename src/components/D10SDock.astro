---
// Floating D10S launcher — a small living red sphere on the right edge.
// Pressed, it carries the visitor back to the agent. Appears once the agent
// section has been scrolled past (symmetric to the back-to-top on the left).
import type { Lang } from '../i18n/content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const label: Record<Lang, string> = { en: 'Back to D10S', it: 'Torna a D10S', es: 'Volver a D10S' };
---

<button id="d10s-dock" type="button" class="d10s-dock" aria-label={label[lang]}>
  <span class="d10s-dock-core" aria-hidden="true"></span>
</button>

<script>
  const dock = document.getElementById('d10s-dock');
  const target = document.getElementById('agent-demo');
  if (dock && target) {
    dock.addEventListener('click', () =>
      target.scrollIntoView({ behavior: 'smooth', block: 'center' })
    );
    // Show the dock only when the agent section sits above the viewport
    // (i.e. the visitor has scrolled past it and might want to return).
    const io = new IntersectionObserver(
      ([e]) => {
        const passed = !e.isIntersecting && e.boundingClientRect.top < 0;
        dock.classList.toggle('is-on', passed);
      },
      { threshold: 0 }
    );
    io.observe(target);
  }
</script>
