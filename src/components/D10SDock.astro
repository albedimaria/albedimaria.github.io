---
// Floating D10S seal — bottom-right. A red sphere (living voice waveform) inside
// a STATIC seal: a question above, the action below, dots at the sides. The words
// are always legible (a sphere on its own is mystery meat) and never spin — a text
// ring rotating forever in the viewport is noise, not an affordance.
//
// Two separate arcs, not one circle: on a single circular path the bottom half of
// the text renders upside-down. Top arc runs left→right over the top (glyphs fall
// outward), bottom arc left→right through the bottom (glyphs fall inward), so both
// read upright and the two bands sit at the same distance from the sphere. The
// tracking differs per arc (set in CSS) so both cover the same angle — that is what
// keeps the side dots equidistant from the two texts.
//
// Visibility and clicks are owned by AgentDemo: the seal and the docked panel are
// mutually exclusive, so a single script decides which one is up.
import type { Lang } from '../i18n/content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const label: Record<Lang, string> = { en: 'Ask D10S', it: 'Chiedi a D10S', es: 'Pregunta a D10S' };
const top: Record<Lang, string> = { en: 'any questions?', it: 'hai domande?', es: '¿alguna duda?' };
const bottom: Record<Lang, string> = { en: 'ask the agent', it: 'chiedi all’agente', es: 'pregunta al agente' };

// Both arcs must cover the SAME angle, or the side dots stop sitting halfway
// between the two texts. Same span, different radius and different string length
// → the tracking has to be solved per arc AND per language, not hardcoded.
//   span 150° · font 9px · monospace advance 0.602em = 5.418 units/char
const SPAN = (150 * Math.PI) / 180;
const ADVANCE = 5.418;
const track = (text: string, radius: number) =>
  `letter-spacing:${((radius * SPAN) / text.length - ADVANCE).toFixed(2)}px`;
---

<button id="d10s-dock" type="button" class="d10s-dock" aria-label={label[lang]}>
  <svg class="d10s-seal" viewBox="0 0 100 100" aria-hidden="true">
    <defs>
      <path id="seal-top" d="M 15,50 A 35,35 0 0 1 85,50" />
      <path id="seal-bottom" d="M 8.7,50 A 41.3,41.3 0 0 0 91.3,50" />
    </defs>
    <text style={track(top[lang], 35)}><textPath href="#seal-top" startOffset="50%" text-anchor="middle">{top[lang]}</textPath></text>
    <text style={track(bottom[lang], 41.3)}><textPath href="#seal-bottom" startOffset="50%" text-anchor="middle">{bottom[lang]}</textPath></text>
    <circle class="seal-dot" cx="11.9" cy="50" r="1.4" />
    <circle class="seal-dot" cx="88.1" cy="50" r="1.4" />
  </svg>

  <span class="d10s-dock-orb" aria-hidden="true">
    <span class="d10s-dock-glyph"><i></i><i></i><i></i><i></i><i></i></span>
  </span>
</button>
