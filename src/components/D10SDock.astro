---
// Floating D10S launcher — bottom-right. A living red sphere (tiny voice
// waveform) preceded by an always-visible label: the words are what make the
// sphere legible, so they never hide behind hover. Pressed, it carries the
// visitor back to the agent. Appears once the agent section is scrolled past.
import type { Lang } from '../i18n/content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const label: Record<Lang, string> = { en: 'Back to D10S', it: 'Torna a D10S', es: 'Volver a D10S' };
const cta: Record<Lang, string> = { en: 'ask the agent', it: 'chiedi all’agente', es: 'pregunta al agente' };
---

<button id="d10s-dock" type="button" class="d10s-dock" aria-label={label[lang]}>
  <span class="d10s-dock-label" aria-hidden="true">{cta[lang]}</span>
  <span class="d10s-dock-orb" aria-hidden="true">
    <span class="d10s-dock-glyph"><i></i><i></i><i></i><i></i><i></i></span>
  </span>
</button>

<script>
  const dock = document.getElementById('d10s-dock');
  const target = document.getElementById('agent-demo');
  if (dock && target) {
    dock.addEventListener('click', () =>
      target.scrollIntoView({ behavior: 'smooth', block: 'center' })
    );
    // Show as soon as the agent starts leaving upward — when its bottom rises
    // past ~60% of the viewport you're already moving into the next section.
    let ticking = false;
    const update = () => {
      ticking = false;
      const r = target.getBoundingClientRect();
      dock.classList.toggle('is-on', r.bottom < window.innerHeight * 0.6);
    };
    const onScroll = () => { if (!ticking) { ticking = true; requestAnimationFrame(update); } };
    window.addEventListener('scroll', onScroll, { passive: true });
    window.addEventListener('resize', onScroll, { passive: true });
    update();
  }
</script>
