---
// Floating D10S launcher — a living red sphere on the right edge. At rest it
// shows a tiny voice waveform; on hover a rotating "chiedi a d10s" seal spins
// up around it (the words ARE the affordance). Pressed, it carries the visitor
// back to the agent. Appears once the agent section has been scrolled past.
import type { Lang } from '../i18n/content';
interface Props { lang: Lang }
const { lang } = Astro.props;
const label: Record<Lang, string> = { en: 'Back to D10S', it: 'Torna a D10S', es: 'Volver a D10S' };
const seal: Record<Lang, string> = { en: 'ask d10s', it: 'chiedi a d10s', es: 'pregunta a d10s' };
const ring = `${seal[lang]} · ${seal[lang]} · `;
---

<button id="d10s-dock" type="button" class="d10s-dock" aria-label={label[lang]}>
  <svg class="d10s-seal" viewBox="0 0 100 100" aria-hidden="true">
    <defs>
      <path id="d10s-seal-path" d="M50,50 m-38,0 a38,38 0 1,1 76,0 a38,38 0 1,1 -76,0" />
    </defs>
    <text><textPath href="#d10s-seal-path" startOffset="0">{ring}</textPath></text>
  </svg>
  <span class="d10s-dock-glyph" aria-hidden="true"><i></i><i></i><i></i><i></i><i></i></span>
</button>

<script>
  const dock = document.getElementById('d10s-dock');
  const target = document.getElementById('agent-demo');
  if (dock && target) {
    dock.addEventListener('click', () =>
      target.scrollIntoView({ behavior: 'smooth', block: 'center' })
    );
    const io = new IntersectionObserver(
      ([e]) => {
        const passed = !e.isIntersecting && e.boundingClientRect.top < 0;
        dock.classList.toggle('is-on', passed);
      },
      { threshold: 0 }
    );
    io.observe(target);
  }
</script>
