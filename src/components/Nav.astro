---
import BrandMark from './BrandMark.astro';
// Three-zone header: rotating octahedron brand mark · centered nav · language switch
---

<header class="sticky top-0 z-30 border-b border-bone/10 bg-ink/80 backdrop-blur">
  <nav class="grid w-full grid-cols-3 items-center px-5 py-5 md:px-8" aria-label="Primary">
    <div class="justify-self-start">
      <BrandMark />
    </div>

    <ul class="flex justify-center gap-6 font-mono text-xs lowercase tracking-wide text-text-muted">
      <li><a href="#work" class="transition hover:text-bone">work</a></li>
      <li><a href="#about" class="transition hover:text-bone">about</a></li>
      <li><a href="#contact" class="transition hover:text-bone">contact</a></li>
    </ul>

    <ul class="flex justify-end gap-3 font-mono text-xs">
      <li><a href="/" class="text-bone" aria-current="true">EN</a></li>
      <li><a href="/it/" class="text-text-dim transition hover:text-bone">IT</a></li>
      <li><a href="/es/" class="text-text-dim transition hover:text-bone">ES</a></li>
    </ul>
  </nav>
</header>
