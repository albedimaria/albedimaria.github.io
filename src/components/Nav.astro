---
import BrandMark from './BrandMark.astro';
import { ui, langLabels, localizedHome, langs, type Lang } from '../i18n/content';

interface Props {
  lang: Lang;
}
const { lang } = Astro.props;
const t = ui[lang];

const navItems = [
  { href: '#work', label: t.nav.work },
  { href: '#about', label: t.nav.about },
  { href: '#contact', label: t.nav.contact },
];
---

<header class="sticky top-0 z-30 border-b border-bone/10 bg-ink/80 backdrop-blur">
  <nav class="flex items-center gap-4 px-5 py-4 md:px-8" aria-label="Primary">
    <BrandMark />

    <!-- desktop nav (centered) -->
    <ul class="hidden flex-1 justify-center gap-8 font-mono text-[13px] lowercase tracking-wide text-text-muted md:flex">
      {navItems.map((i) => (
        <li><a href={i.href} class="transition hover:text-bone">{i.label}</a></li>
      ))}
    </ul>

    <!-- desktop language dropdown -->
    <div class="relative ml-auto hidden md:block">
      <button id="lang-btn" type="button" class="flex items-center gap-1.5 font-mono text-[12px] text-bone" aria-haspopup="true" aria-expanded="false" aria-label="Change language">
        {langLabels[lang]} <span class="text-text-dim">▾</span>
      </button>
      <ul id="lang-menu" class="absolute right-0 mt-2 hidden min-w-[64px] overflow-hidden rounded-[var(--radius-btn)] border border-bone/15 bg-surface py-1">
        {langs.map((l) => (
          <li>
            <a href={localizedHome[l]} data-lang-link class:list={['block px-3.5 py-1.5 font-mono text-[12px] transition hover:bg-ink-2', l === lang ? 'text-bone' : 'text-text-muted hover:text-bone']} aria-current={l === lang ? 'true' : undefined}>
              {langLabels[l]}
            </a>
          </li>
        ))}
      </ul>
    </div>

    <!-- mobile hamburger -->
    <button id="menu-btn" type="button" class="ml-auto text-bone md:hidden" aria-label="Open menu" aria-expanded="false" aria-controls="mobile-menu">
      <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
        <path d="M4 7h16" /><path d="M4 12h16" /><path d="M4 17h16" />
      </svg>
    </button>
  </nav>
</header>

<!-- mobile full-screen menu — OUTSIDE <header> so its fixed positioning is the viewport,
     not the backdrop-filtered header (which would confine and clip it) -->
<div id="mobile-menu" class="fixed inset-0 z-50 hidden bg-ink md:hidden">
    <div class="flex items-center justify-end border-b border-bone/10 px-5 py-4">
      <button id="menu-close" type="button" class="text-bone" aria-label="Close menu">
        <svg width="26" height="26" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8" stroke-linecap="round" aria-hidden="true">
          <path d="M6 6l12 12" /><path d="M18 6L6 18" />
        </svg>
      </button>
    </div>
    <div class="grid flex-1 grid-cols-[1fr_auto] items-center gap-6 px-8">
      <ul class="flex flex-col gap-8 font-display text-4xl text-bone">
        {navItems.map((i) => (
          <li><a href={i.href} class="inline-block transition hover:text-white">{i.label}</a></li>
        ))}
      </ul>
      <div class="flex flex-col items-end gap-5 self-center border-l border-bone/10 pl-6 font-mono text-lg">
        {langs.map((l) => (
          <a href={localizedHome[l]} data-lang-link class={l === lang ? 'text-bone' : 'text-text-muted transition hover:text-bone'} aria-current={l === lang ? 'true' : undefined}>
            {langLabels[l]}
          </a>
        ))}
      </div>
    </div>
  </div>

<script>
  // Preserve scroll position when switching language (same layout across locales,
  // so the section stays roughly in place instead of jumping back to the top).
  (() => {
    document.querySelectorAll('[data-lang-link]').forEach((a) =>
      a.addEventListener('click', () => {
        try { sessionStorage.setItem('vc_scroll', String(window.scrollY)); } catch {}
      })
    );
    let y: number | null = null;
    try {
      const s = sessionStorage.getItem('vc_scroll');
      if (s !== null) { y = parseInt(s, 10); sessionStorage.removeItem('vc_scroll'); }
    } catch {}
    if (y !== null) {
      const target = y;
      if ('scrollRestoration' in history) history.scrollRestoration = 'manual';
      window.scrollTo(0, target);
      window.addEventListener('load', () => window.scrollTo(0, target));
    }
  })();

  const menuBtn = document.getElementById('menu-btn');
  const menu = document.getElementById('mobile-menu');
  const menuClose = document.getElementById('menu-close');

  const convai = document.querySelector('elevenlabs-convai') as HTMLElement | null;
  const openMenu = () => {
    menu?.classList.remove('hidden');
    menu?.classList.add('flex', 'flex-col');
    menuBtn?.setAttribute('aria-expanded', 'true');
    document.body.style.overflow = 'hidden';
    if (convai) convai.style.display = 'none';
  };
  const closeMenu = () => {
    menu?.classList.add('hidden');
    menu?.classList.remove('flex', 'flex-col');
    menuBtn?.setAttribute('aria-expanded', 'false');
    document.body.style.overflow = '';
    if (convai) convai.style.display = '';
  };

  menuBtn?.addEventListener('click', openMenu);
  menuClose?.addEventListener('click', closeMenu);
  menu?.querySelectorAll('a').forEach((a) => a.addEventListener('click', closeMenu));

  const langBtn = document.getElementById('lang-btn');
  const langMenu = document.getElementById('lang-menu');
  langBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const willOpen = langMenu?.classList.contains('hidden');
    langMenu?.classList.toggle('hidden');
    langBtn.setAttribute('aria-expanded', String(!!willOpen));
  });
  document.addEventListener('click', () => {
    langMenu?.classList.add('hidden');
    langBtn?.setAttribute('aria-expanded', 'false');
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      closeMenu();
      langMenu?.classList.add('hidden');
    }
  });
</script>
